<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UserGUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UserGUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="LPCsynthesizer"
        Background="#5A1622"
        Foreground="#C8E6FF">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,*" Margin="10">
 
        <!-- ═══════════════════════════════════════════════
             Övre rad: Knappar | Skjutreglage | Label/Bild
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Margin="0,0,0,8">
 
            <!-- 2×2 Knappar -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,Auto,Auto, Auto"
                  ColumnDefinitions="Auto,Auto,Auto"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0">
                <Button Grid.Row="0" Grid.Column="0"
                        Foreground="AliceBlue"  Content="Load File" Width="130" Height="36" Margin="4"/>
                <TextBox Text="Input File" Grid.Row="0" Grid.Column="1" PlaceholderText="Input file"/>
                <Button Grid.Row="1" Grid.Column="0"
                        Foreground="AliceBlue" Content="Generate" Width="130" Height="36" Margin="4"/>
                <TextBox Text="Output File" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" PlaceholderText="Output file"/>
                <Button Grid.Row="2" Grid.Column="0"
                        Background="{Binding LPCEngineActive}"  
                        Foreground="AliceBlue" Content="{Binding LPCEngineStatus}" Width="130" Height="36" Margin="4" 
                        Command="{Binding StartStopEngine}" />
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
                <Button Background="{Binding RecButtonBackground}" Foreground="Aqua" Margin="2" Content="Rec" Command="{Binding OnStartStopRecording}"
                />
                <Button Background="{Binding PlayButtonBackground}" Foreground="Aqua" Margin="2" Content="Play" Command="{Binding OnPlayRecording}" />
            </StackPanel>
            </Grid>
 
            <!-- 5 vertikala skjutreglage -->
                <Grid Grid.Column="1" HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RowSpacing="10"
                ColumnDefinitions="100,100,100,100,100" RowDefinitions="Auto,Auto,Auto"  Margin="4">
                <Slider Orientation="Vertical" Grid.Row="0" Grid.Column="0"
                                        Height="160" Width="28"
                                        Minimum="0" Maximum="100"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        Value="{Binding LoopSpeedValue}" />       
                <Slider Orientation="Vertical" Grid.Row="0" Grid.Column="1"
                                        Height="160" Width="28"
                                        Minimum="0" Maximum="24"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        Value="{Binding PitchSliderValue}" />
                        <Slider Orientation="Vertical" Grid.Row="0" Grid.Column="2"
                                        Height="160" Width="28"
                                        Minimum="85" Maximum="115"
                                        Value="{Binding FormantSliderValue}" />
                        <Slider Orientation="Vertical" Grid.Row="0" Grid.Column="3"
                                        Height="160" Width="28"
                                        Minimum="0" Maximum="100" Value="75"/>
                        <Slider Orientation="Vertical" Grid.Row="0" Grid.Column="4"
                                        Height="160" Width="28"
                                        Minimum="0" Maximum="100" Value="50"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                Text="Loop speed" 
                                TextAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                Text="Frequency" 
                                TextAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                Text="Formant"
                                TextAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                Text="Poles"
                                TextAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="4"
                                Text="Transform"
                                TextAlignment="Center"/>
                        
                </Grid>
 
            <!-- Label / Bild + knappar -->
            <StackPanel Grid.Column="2"
                        Orientation="Vertical"
                        VerticalAlignment="Top"
                        Spacing="6">
                <Border Background="#2196F3"
                        Width="160" Height="80"
                        CornerRadius="3">
                    <Image Source="avares://UserGUI/Assets/lips.png" Stretch="UniformToFill"/>
                </Border>
                <Button Foreground="AliceBlue" Content="Fixed pitch" Command="{Binding OnRobot }" Width="160" Height="36"/>
                <Button Foreground="AliceBlue" Content="Voice/Unvoiced" Command="{Binding OnVoiceUnvoiced}" Width="160" Height="36"/>
            </StackPanel>
        </Grid>
 
        <!-- ═══════════════════════════════
             Vågform 1
             ═══════════════════════════════ -->
        <Border Grid.Row="1"
                BorderBrush="#111111"
                BorderThickness="2"
                Background="#1A1A1A"
                Margin="0,4,0,4"
                CornerRadius="2">
            <Canvas x:Name="WaveformCanvas1"
                    Background="Transparent"
                    ClipToBounds="True"/>
        </Border>
 
        <!-- ═══════════════════════════════
             Vågform 2
             ═══════════════════════════════ -->
        <Border Grid.Row="2"
                BorderBrush="#111111"
                BorderThickness="2"
                Background="#1A1A1A"
                Margin="0,4,0,0"
                CornerRadius="2">
            <Canvas x:Name="WaveformCanvas2"
                    Background="Transparent"
                    ClipToBounds="True"/>
        </Border>
 
    </Grid>
</Window>
